LEADERBOARD_APP_NAME=Global Gaming Leaderboard
LEADERBOARD_ENVIRONMENT=local
LEADERBOARD_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leaderboard
LEADERBOARD_REDIS_URL=redis://localhost:6379/0
LEADERBOARD_DEFAULT_LEADERBOARD_LIMIT=10
LEADERBOARD_MAX_LEADERBOARD_LIMIT=100
LEADERBOARD_DEFAULT_CONTEXT_WINDOW=2
LEADERBOARD_MAX_CONTEXT_WINDOW=10
LEADERBOARD_REQUEST_TIMEOUT_SECONDS=5
LEADERBOARD_LOG_LEVEL=INFO

